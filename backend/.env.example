# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Default in code when unset: claude-opus-4-7 (best pairing with dynamic web search).
# Use claude-sonnet-4-6 if you prefer lower cost/latency with the same tools.
ANTHROPIC_MODEL=claude-opus-4-7

# Server web-search tool revision. Default in code when unset:
# web_search_20260209 (dynamic filtering, less raw HTML vs 20250305).
# Fallback for older setups: WEB_SEARCH_TOOL_TYPE=web_search_20250305
WEB_SEARCH_TOOL_TYPE=web_search_20260209

# If true: sets allowed_callers=["direct"] on the web search tool (ZDR-compatible;
# skips the dynamic code-filtering path — see Anthropic server-tools docs).
WEB_SEARCH_DIRECT_ONLY=false

# Maximum upload size per file in megabytes
MAX_FILE_MB=20

# Max web searches per answer call. Defaults to 10 in code — enough for the
# largest section. Starter Anthropic tiers (30k input tokens/min) typically
# need MAX_WEB_SEARCHES=1 combined with sequential answering (below).
MAX_WEB_SEARCHES=10

# Concurrency caps. Starter tier (30k tpm): ANSWER_CONCURRENCY=1 and a delay
# (e.g. 45s). Higher tiers may raise concurrency and set delay to 0.
ANSWER_CONCURRENCY=1
ANSWER_INTER_CALL_DELAY_SECONDS=45
VALIDATION_CONCURRENCY=2

# When true, attach raw PDF/image bytes to validation calls. Default false:
# we send extracted text only, which uses far fewer input tokens.
VALIDATION_ATTACH_DOCUMENTS=false

# Use Anthropic prompt caching on validation calls.
ENABLE_PROMPT_CACHING=true

MAX_RETRIES=5

# When every SDK retry still sees HTTP 529 (overloaded), wait and retry the
# whole request this many extra times (exponential backoff from base delay).
ANTHROPIC_OVERLOAD_EXTRA_ATTEMPTS=3
ANTHROPIC_OVERLOAD_BASE_DELAY_SECONDS=10

# Comma-separated list of allowed CORS origins for local development
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://127.0.0.1:8080,http://127.0.0.1:5173
