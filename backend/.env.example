# =============================================================================
# Secrets and credentials only — models, limits, and CORS live in app/config.py
# =============================================================================

# Google AI Studio / Gemini API (required). Alias: GOOGLE_API_KEY
GEMINI_API_KEY=

# Postgres password (optional — enables history against Railway Postgres).
# Host/port/user/db defaults are in app/config.py.
DATABASE_PASSWORD=

# Reference URL fetches (optional but strongly recommended): set contact so bots
# can identify you (Wikipedia-style default for generic hosts), e.g.
#   https://example.com/kyc; kyc-team@example.com
REFERENCE_URL_FETCH_CONTACT=

# Strongly recommended for www.sec.gov / data.sec.gov (EDGAR): SEC expects a declared
# User-Agent like "YourProjectName you@yourdomain.com" (name + email or URL). See SEC
# "Accessing EDGAR Data". Overrides SEC-specific and Wikimedia-style defaults below.
REFERENCE_URL_FETCH_USER_AGENT=

# If unset for SEC (*.sec.gov): when contact above includes an email, that email is used;
# otherwise the whole contact string is appended after KYC-Automation.

# S3-compatible uploads (required when users attach files).
S3_ENDPOINT_URL=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
