# Google AI Studio / Gemini API key (required). Alias: GOOGLE_API_KEY
GEMINI_API_KEY=

# Gemini 3.x ids enable JSON-schema answers *together* with Google Search in this app.
# gemini-2.5-* often finishes with FinishReason.OTHER and 0 output parts here (blank rows).
# Default in code when unset: gemini-3.1-flash-preview
GEMINI_MODEL=gemini-3.1-flash-preview

# Root log level for the backend (DEBUG shows JSON parse retries and similar).
LOG_LEVEL=INFO

# Maximum upload size per file in megabytes
MAX_FILE_MB=20

# Concurrency caps — tune for your API quota.
ANSWER_CONCURRENCY=1
ANSWER_INTER_CALL_DELAY_SECONDS=45
VALIDATION_CONCURRENCY=2

# When true, attach raw PDF/image bytes to validation calls. Default false:
# we send extracted text only, which uses far fewer input tokens.
VALIDATION_ATTACH_DOCUMENTS=false

# When true, attach Anthropic-style cache markers to the stable document prefix
# (ignored by Gemini; keeps logging parity).
ENABLE_PROMPT_CACHING=true

# When transient quota/overload errors persist after SDK retries, wait and retry
# the whole request this many extra times (exponential backoff from base delay).
GEMINI_OVERLOAD_EXTRA_ATTEMPTS=3
GEMINI_OVERLOAD_BASE_DELAY_SECONDS=10

# Comma-separated list of allowed CORS origins for local development
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://127.0.0.1:8080,http://127.0.0.1:5173
