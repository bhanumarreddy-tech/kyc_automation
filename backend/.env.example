# =============================================================================
# Secrets and credentials only — models, limits, and most tuning live in app/config.py
# =============================================================================

# Deploy environment for CORS pairing with the Cloudflare Workers UI.
# Set on each Railway service (not needed for local dev):
#   APP_ENV=staging     → allow https://kyc-automation-staging.bhanu-marreddy.workers.dev
#   APP_ENV=production  → allow https://kycautomation.bhanu-marreddy.workers.dev
# Optional override (comma-separated origins):
# CORS_ALLOWED_ORIGINS=https://kyc-automation-staging.bhanu-marreddy.workers.dev

# Google AI Studio / Gemini API (required). Alias: GOOGLE_API_KEY
GEMINI_API_KEY=

# Postgres (optional — enables submission history). Copy from Railway Postgres plugin.
# Local dev: DATABASE_PUBLIC_URL (public proxy + sslmode=require).
# Railway API service: DATABASE_URL (private TCP) when Postgres is linked; if only
# DATABASE_PUBLIC_URL is shared into the service, the app uses that as a fallback.
POSTGRES_DB=
PGUSER=
PGPORT=
PGHOST=
POSTGRES_PASSWORD=
PGDATABASE=
PGPASSWORD=
DATABASE_URL=
DATABASE_PUBLIC_URL=

# Railway Postgres plugin only (not read by this app):
# PGDATA=/var/lib/postgresql/data/pgdata
# SSL_CERT_DAYS=820
# RAILWAY_DEPLOYMENT_DRAINING_SECONDS=60

# Reference URL fetches (optional but strongly recommended): set contact so bots
# can identify you (Wikipedia-style default for generic hosts), e.g.
#   https://example.com/kyc; kyc-team@example.com
REFERENCE_URL_FETCH_CONTACT=

# Strongly recommended for www.sec.gov / data.sec.gov (EDGAR): SEC expects a declared
# User-Agent like "YourProjectName you@yourdomain.com" (name + email or URL). See SEC
# "Accessing EDGAR Data". Overrides SEC-specific and Wikimedia-style defaults below.
REFERENCE_URL_FETCH_USER_AGENT=

# If unset for SEC (*.sec.gov): when contact above includes an email, that email is used;
# otherwise the whole contact string is appended after KYC-Automation.

# Source links (Gemini citations): optional HTTP probe drops broken URLs / EDGAR index fallback.
# Requires REFERENCE_URL_FETCH_CONTACT or REFERENCE_URL_FETCH_USER_AGENT for www.sec.gov.
# Defaults in config.py verify EDGAR Archives paths only unless you widen scope below.
# SOURCE_URL_VERIFY_ENABLED=true
# SOURCE_URL_VERIFY_EDGAR_ONLY=true   # when true, skips probes for non-Archives citations
# SOURCE_URL_VERIFY_TIMEOUT_SECONDS=15
# SOURCE_URL_VERIFY_MAX_URLS=250

# Max clickable sources per questionnaire row after SEC hub reorder (2–3).
# Hub links appear first when the issuer matched EDGAR; remaining slots fill from search.
# ANSWER_SOURCES_MAX_COUNT=3

# When true (default in config.py), Sources use Gemini search grounding chunk URIs
# (and drop model URLs not present there). Set false to keep raw model citations only.
# ANSWER_SOURCES_USE_GROUNDING_METADATA=true

# Validation RAG (requires Postgres with pgvector extension). Tuning defaults in app/config.py.
# RAG_ENABLED=true
# RAG_EMBEDDING_MODEL=gemini-embedding-001
# RAG_EMBEDDING_DIMENSIONS=768
# RAG_CONTEXTUALIZE=true
# RAG_PER_QUESTION=true
# RAG_RERANK_TOP_K=3              # top chunks per question (recall pass uses RAG_RECALL_RERANK_TOP_K=6)
# VALIDATION_CHUNKS_PER_QUESTION=3
# VALIDATION_CONCURRENCY=32       # bounded parallel question validations; lower if you hit 429 rate limits

# MLflow GenAI tracing for RAG observability (view with: mlflow ui --port 5000)
# MLFLOW_TRACING_ENABLED=true
# MLFLOW_TRACKING_URI=file:./mlruns
# MLFLOW_EXPERIMENT_NAME=kyc-rag-validation

# S3-compatible uploads (required when users attach files).
S3_ENDPOINT_URL=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
