# =============================================================================
# Secrets and credentials only — models, limits, and CORS live in app/config.py
# =============================================================================

# Google AI Studio / Gemini API (required). Alias: GOOGLE_API_KEY
GEMINI_API_KEY=

# Postgres password (optional — enables history against Railway Postgres).
# Host/port/user/db defaults are in app/config.py.
DATABASE_PASSWORD=

# Reference URL fetches (optional but strongly recommended): set contact so bots
# can identify you (Wikipedia-style default for generic hosts), e.g.
#   https://example.com/kyc; kyc-team@example.com
REFERENCE_URL_FETCH_CONTACT=

# Strongly recommended for www.sec.gov / data.sec.gov (EDGAR): SEC expects a declared
# User-Agent like "YourProjectName you@yourdomain.com" (name + email or URL). See SEC
# "Accessing EDGAR Data". Overrides SEC-specific and Wikimedia-style defaults below.
REFERENCE_URL_FETCH_USER_AGENT=

# If unset for SEC (*.sec.gov): when contact above includes an email, that email is used;
# otherwise the whole contact string is appended after KYC-Automation.

# Source links (Gemini citations): optional HTTP probe drops broken URLs / EDGAR index fallback.
# Requires REFERENCE_URL_FETCH_CONTACT or REFERENCE_URL_FETCH_USER_AGENT for www.sec.gov.
# Defaults in config.py verify EDGAR Archives paths only unless you widen scope below.
# SOURCE_URL_VERIFY_ENABLED=true
# SOURCE_URL_VERIFY_EDGAR_ONLY=true   # when true, skips probes for non-Archives citations
# SOURCE_URL_VERIFY_TIMEOUT_SECONDS=15
# SOURCE_URL_VERIFY_MAX_URLS=250

# Max clickable sources per questionnaire row after SEC hub reorder (2–3).
# Hub links appear first when the issuer matched EDGAR; remaining slots fill from search.
# ANSWER_SOURCES_MAX_COUNT=3

# When true (default in config.py), Sources use Gemini search grounding chunk URIs
# (and drop model URLs not present there). Set false to keep raw model citations only.
# ANSWER_SOURCES_USE_GROUNDING_METADATA=true

# S3-compatible uploads (required when users attach files).
S3_ENDPOINT_URL=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
