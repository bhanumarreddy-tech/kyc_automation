# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Claude model name (optional, defaults to claude-sonnet-4-5)
ANTHROPIC_MODEL=claude-sonnet-4-5

# Maximum upload size per file in megabytes
MAX_FILE_MB=20

# Max web searches per Claude answer call. Defaults to 10 so the
# largest section (Section 1 - Legal Identity has 9 distinct fact
# questions) has enough budget. Web searches are a server-side tool
# and do not count against the input-token per-minute rate limit.
MAX_WEB_SEARCHES=10

# Concurrency caps. Keep these low if you are on a small Anthropic tier
# (e.g. 30k input tokens / minute). With these defaults a typical
# submission fits comfortably under that limit.
ANSWER_CONCURRENCY=4
VALIDATION_CONCURRENCY=2

# When true, attach raw PDF/image bytes to validation calls. Default false:
# we send extracted text only, which uses far fewer input tokens. Set to
# true only if you have a higher rate-limit tier and need image grounding.
VALIDATION_ATTACH_DOCUMENTS=false

# Use Anthropic prompt caching on the shared "company + documents" prefix
# of validation calls. The first of 8 section calls writes the cache and
# the remaining 7 read it at ~10% of the input-token cost and rate-limit
# weight. Has no effect if the prefix is below the ~1024-token minimum.
ENABLE_PROMPT_CACHING=true

# How many times the Anthropic SDK should retry a request before giving up
# (used to ride out transient 429s).
MAX_RETRIES=5

# Comma-separated list of allowed CORS origins for local development
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://127.0.0.1:8080,http://127.0.0.1:5173
