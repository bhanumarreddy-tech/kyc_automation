FROM python:3.12-slim-bookworm

WORKDIR /app

ENV PYTHONUNBUFFERED=1
ENV GIT_PYTHON_REFRESH=quiet
ENV PORT=5000

COPY requirements-mlflow-ui.txt .
RUN pip install --no-cache-dir -r requirements-mlflow-ui.txt

COPY scripts/start_mlflow_ui.sh /app/start_mlflow_ui.sh
RUN chmod +x /app/start_mlflow_ui.sh

EXPOSE 5000

CMD ["/app/start_mlflow_ui.sh"]
