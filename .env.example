# Frontend environment template.
# Copy to `.env.development`, `.env.staging`, or `.env.production` as needed.

# Local dev (`npm run dev`): leave unset so Vite proxies `/api/*` to localhost:8000.
# VITE_API_BASE_URL=

# Staging build (`npm run build:staging`):
# VITE_API_BASE_URL=https://your-staging-api.example.com

# Production build (`npm run build:production`):
# VITE_API_BASE_URL=https://your-production-api.example.com
